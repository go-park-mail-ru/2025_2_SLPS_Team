{
  "profile_index": {
    "settings": {
      "analysis": {
        "filter": {
          "russian_morphology": { "type": "snowball", "language": "russian" },
          "english_morphology": { "type": "snowball", "language": "english" },
          "edge_ngram_filter": { "type": "edge_ngram", "min_gram": 2, "max_gram": 20 },
          "name_phonetic": { "type": "phonetic", "encoder": "metaphone", "languageset": ["russian","english"], "replace": false },
          "name_synonyms": { "type": "synonym", "synonyms_path": "elastic/synonyms_profile.txt" }
        },
        "analyzer": {
          "name_index_analyzer": {
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding",
              "russian_morphology",
              "english_morphology",
              "name_synonyms",
              "name_phonetic",
              "edge_ngram_filter"
            ]
          },
          "name_search_analyzer": {
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding",
              "russian_morphology",
              "english_morphology",
              "name_synonyms",
              "name_phonetic"
            ]
          }
        }
      }
    },
    "mappings": {
      "properties": {
        "full_name": {
          "type": "text",
          "analyzer": "name_index_analyzer",
          "search_analyzer": "name_search_analyzer"
        },
        "full_name_translit": {
          "type": "text",
          "analyzer": "name_index_analyzer",
          "search_analyzer": "name_search_analyzer"
        },
        "user_id": { "type": "integer" }
      }
    }
  },
  "community_index": {
    "settings": {
      "analysis": {
        "filter": {
          "russian_morphology": { "type": "snowball", "language": "russian" },
          "english_morphology": { "type": "snowball", "language": "english" },
          "edge_ngram_filter": { "type": "edge_ngram", "min_gram": 2, "max_gram": 20 },
          "name_phonetic": { "type": "phonetic", "encoder": "metaphone", "languageset": ["russian", "english"], "replace": false },
          "name_synonyms": { "type": "synonym", "synonyms_path": "elastic/synonyms_community.txt" }
        },
        "analyzer": {
          "name_index_analyzer": {
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding",
              "russian_morphology",
              "english_morphology",
              "name_synonyms",
              "name_phonetic",
              "edge_ngram_filter"
            ]
          },
          "name_search_analyzer": {
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding",
              "russian_morphology",
              "english_morphology",
              "name_synonyms",
              "name_phonetic"
            ]
          }
        }
      }
    },
    "mappings": {
      "properties": {
        "community_id": {
          "type": "integer"
        },
        "community_name": {
          "type": "text",
          "analyzer": "name_index_analyzer",
          "search_analyzer": "name_search_analyzer"
        },
        "community_name_translit": {
          "type": "text",
          "analyzer": "name_index_analyzer",
          "search_analyzer": "name_search_analyzer"
        }
      }
    }
  }
}
